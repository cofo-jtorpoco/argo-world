# Chart versions pinned from `helm search repo argo/*` on 2026-07-15.
# App versions shown for reference; argo-events v1.9.11 includes the 1-replica
# JetStream fix (issue #2743) this demo relies on.
ARGO_HELM_REPO=https://argoproj.github.io/argo-helm

ARGOCD_CHART_VERSION=10.1.3        # app v3.4.5
WORKFLOWS_CHART_VERSION=1.0.19     # app v4.0.7
EVENTS_CHART_VERSION=2.4.23        # app v1.9.11
ROLLOUTS_CHART_VERSION=2.41.0      # app v1.9.0

# Namespaces (one per layer + one for the app)
NS_ARGOCD=argocd
NS_WORKFLOWS=argo
NS_EVENTS=argo-events
NS_ROLLOUTS=argo-rollouts
NS_APP=worldcup

# Where Argo CD syncs the platform + apps from
GIT_REPO=https://github.com/cofo-jtorpoco/argo-world.git
GIT_REVISION=main
GIT_PATH=gitops/root

# Container registry
IMAGE_REPO=ghcr.io/cofo-jtorpoco/argo-world
IMAGE_TAG=v1
